# 媒体文件根目录（宿主机路径）
# 复制此文件为 .env 并填写实际路径
# JAV 任务默认使用 $MEDIA_ROOT/jav_workspace/ 下的 inbox、sorted、unsorted 等子目录（需自行创建）。
# Raw 收件箱整理使用 $MEDIA_ROOT/raw_workspace/ 及配置中的各 folders_* / files_* 子路径（需自行创建或按需调整 task_config.yaml）。
MEDIA_ROOT=/path/to/your/media

# 应用数据目录（config / sqlite / logs），映射到容器内的 /data
# 默认为项目根目录下的 app-data/，通常无需修改
APP_DATA_DIR=./app-data

# 运行用户 UID / GID（可选）
# Unraid 默认 nobody:users 为 99:100，与本镜像默认值一致，通常无需修改
# 在其他系统上可设置为当前用户的 UID/GID（运行 `id` 命令查看）
PUID=99
PGID=100
