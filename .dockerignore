# 版本控制
.git
.gitignore

# 本地环境配置（含宿主机路径，不应进入镜像）
.env

# Python 虚拟环境和缓存（不应进入镜像）
.venv
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
.ruff_cache

# 测试和文档（生产镜像不需要）
tests/
docs/

# 项目说明文件（README.md 需保留：pyproject.toml 声明 readme = "README.md"，构建时必须存在）
*_REPORT.md
*_REVIEW.md
LICENSE

# 开发工具配置
justfile
.pre-commit-config.yaml
.python-version

# 本地运行时数据（不应进入镜像）
app-data/

# 本地测试媒体文件和开发脚本（不应进入镜像）
media/
scripts/

# 构建产物
dist/
build/
*.egg-info
